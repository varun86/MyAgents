# MyAgents 本地构建环境变量配置
# 复制此文件为 .env 并填入你的实际值
# cp .env.example .env

# ============================================================
# Apple 代码签名 (必需 - 用于 macOS App 签名和公证)
# ============================================================

# Developer ID 签名身份
# 查看方式: security find-identity -v -p codesigning
# 格式: "Developer ID Application: Your Name (TEAM_ID)"
APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (XXXXXXXXXX)"

# Apple Team ID (10位字符)
# 查看方式: 访问 https://developer.apple.com/account -> Membership
APPLE_TEAM_ID="XXXXXXXXXX"

# App Store Connect API 密钥 (用于公证 Notarization)
# 创建方式: https://appstoreconnect.apple.com/access/integrations/api
# 1. 创建密钥时选择 "Developer" 权限
# 2. 下载 .p8 文件保存到安全位置

# API 发行者 ID (Issuer ID)
APPLE_API_ISSUER="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# API 密钥 ID
APPLE_API_KEY="XXXXXXXXXX"

# API 密钥文件路径 (.p8 文件)
APPLE_API_KEY_PATH="/path/to/AuthKey_XXXXXXXXXX.p8"

# ============================================================
# Tauri 更新签名 (必需 - 用于自动更新功能)
# ============================================================

# Tauri 更新签名私钥
# 生成方式: npx tauri signer generate -w ~/.tauri/myagents.key
# 私钥内容 (多行，需要用引号包裹)
TAURI_SIGNING_PRIVATE_KEY="dW50cnVzd......完整的私钥内容..."

# 私钥密码 (生成密钥时设置的密码)
TAURI_SIGNING_PRIVATE_KEY_PASSWORD="your-password-here"

# ============================================================
# GitHub Actions 配置说明 (需要单独配置到 GitHub Secrets)
# ============================================================
#
# 除了上面的变量，GitHub Actions 还需要以下额外配置:
#
# APPLE_CERTIFICATE        - .p12 证书的 Base64 编码
#                            导出方式: Keychain Access -> 导出证书为 .p12
#                            编码方式: base64 -i cert.p12 | pbcopy
#
# APPLE_CERTIFICATE_PASSWORD - .p12 证书的密码
#
# APPLE_ID                 - Apple ID 邮箱
#
# APPLE_PASSWORD           - App 专用密码 (非 Apple ID 密码)
#                            生成方式: appleid.apple.com -> 安全 -> App 专用密码

# ============================================================
# 埋点统计配置 (可选 - 用于产品用户使用分析，仅记录核心使用行为，不涉及用户隐私数据与具体内容)
# ============================================================
# 注意: 此为开源项目，埋点默认关闭
# 仅在您想收集自己部署实例的使用数据时启用

# 启用埋点 (设为 true 启用，不设置或其他值则禁用)
VITE_ANALYTICS_ENABLED=false

# 埋点服务 API Key
# 需要自行部署 myagents_analytics 服务并获取 API Key
VITE_ANALYTICS_API_KEY=

# 埋点上报地址 (必须配置才会启用上报)
# VITE_ANALYTICS_ENDPOINT=https://your-analytics-server.com/api/track
VITE_ANALYTICS_ENDPOINT=

# ============================================================
# 团队空间 / 云空间构建配置 (可选 - 默认关闭)
# ============================================================
# 这是构建期能力开关：关闭时团队空间模块不会出现在产品入口里。
# 官方构建或自部署云服务构建时再启用；本地/开源默认保持 false。

# 启用团队空间模块 (设为 true 启用)
MYAGENTS_SPACE_ENABLED=false

# 团队空间服务地址 (启用时必填，必须是 https)
# MYAGENTS_SPACE_BASE_URL=https://space.myagents.io
MYAGENTS_SPACE_BASE_URL=

# 公开客户端标识 (可选，不是密钥；用于服务端识别发行渠道/构建来源)
# MYAGENTS_SPACE_PUBLIC_CLIENT_ID=myagents-desktop-official
MYAGENTS_SPACE_PUBLIC_CLIENT_ID=
