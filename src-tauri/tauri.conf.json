{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MyAgents",
  "version": "0.2.16",
  "identifier": "com.myagents.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web && npm run build:server && npm run build:bridge && npm run build:cli"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self' ipc: tauri: asset: http://ipc.localhost; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: tauri: asset: http://ipc.localhost http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:* https://download.myagents.io; fetch-src 'self' ipc: tauri: asset: http://ipc.localhost http://localhost:* http://127.0.0.1:* https://download.myagents.io; img-src 'self' data: blob: asset: myagents: http://myagents.localhost https://asset.localhost https://download.myagents.io https:; media-src 'self' blob: asset: myagents: http://myagents.localhost http://asset.localhost https://asset.localhost;",
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app",
      "nsis",
      "appimage",
      "deb"
    ],
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../src-tauri/resources/server-dist.js": "server-dist.js",
      "../src-tauri/resources/plugin-bridge-dist.mjs": "plugin-bridge-dist.mjs",
      "../src/server/plugin-bridge/sdk-shim": "plugin-bridge-sdk-shim",
      "../src-tauri/resources/claude-agent-sdk": "claude-agent-sdk",
      "../src-tauri/resources/sharp-runtime": "sharp-runtime",
      "../src-tauri/resources/tsx-runtime": "tsx-runtime",
      "../src-tauri/resources/nodejs": "nodejs",
      "../src/shared": "shared",
      "../bundled-skills": "bundled-skills",
      "../bundled-agents": "bundled-agents",
      "../src-tauri/resources/cli": "cli",
      "../mino": "mino",
      "infoplist/en.lproj/InfoPlist.strings": "en.lproj/InfoPlist.strings",
      "infoplist/zh-Hans.lproj/InfoPlist.strings": "zh-Hans.lproj/InfoPlist.strings"
    },
    "externalBin": [
      "binaries/cuse"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": "Entitlements.plist",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "timestampUrl": null,
      "allowDowngrades": true,
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "template": "nsis/installer.nsi",
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null,
        "installMode": "currentUser",
        "languages": [
          "SimpChinese",
          "English"
        ],
        "displayLanguageSelector": false,
        "customLanguageFiles": {
          "SimpChinese": "nsis/languages/SimpChinese.nsh",
          "English": "nsis/languages/English.nsh"
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY3RkQ5QjIzMTE4RTgyRTkKUldUcGdvNFJJNXY5OTB3T2pnUzVUbjFrV203Zk5ZTDg0NVJRdGI0UVRranJzTUsvM0hGcmFlc0IK",
      "endpoints": [
        "https://download.myagents.io/update/{{target}}.json"
      ]
    }
  }
}
