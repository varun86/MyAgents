{
  "name": "myagents",
  "description": "MyAgents - Desktop Claude Code for everyone. AI-powered productivity, not just for developers.",
  "type": "module",
  "version": "0.2.6",
  "license": "Apache-2.0",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "author": "MyAgents Team <myagents.io@gmail.com>",
  "homepage": "https://myagents.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hAcKlyc/MyAgents.git"
  },
  "bugs": {
    "url": "https://github.com/hAcKlyc/MyAgents/issues"
  },
  "keywords": [
    "claude",
    "ai",
    "agent",
    "desktop",
    "tauri",
    "productivity",
    "anthropic"
  ],
  "scripts": {
    "dev": "./start_dev.sh",
    "dev:web": "vite",
    "build:web": "vite build",
    "build:server": "node scripts/esbuild-bundle.mjs server",
    "build:bridge": "node scripts/esbuild-bundle.mjs bridge",
    "build:cli": "node scripts/esbuild-bundle.mjs cli",
    "build:tsx-runtime": "node scripts/setup-tsx-runtime.mjs",
    "server": "node --import tsx/esm src/server/index.ts",
    "start": "npm run build:web && npm run server",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --cache --cache-location .eslintcache --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --experimental-cli --write .",
    "format:check": "prettier --experimental-cli --check --log-level warn .",
    "generate:sdk-shims": "node --import tsx/esm scripts/generate-sdk-shims.ts",
    "clean": "rm -rf node_modules dist .turbo .eslintcache *.tsbuildinfo src-tauri/target",
    "version": "node scripts/sync-version.js && git add src-tauri/tauri.conf.json src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.119",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/react": "^0.27.19",
    "@hono/node-server": "^2.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "~2.10",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.4",
    "@tauri-apps/plugin-updater": "~2.10",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.16",
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.13.0",
    "js-yaml": "^4.1.1",
    "katex": "^0.16.27",
    "lucide-react": "^0.554.0",
    "mermaid": "^11.12.2",
    "monaco-editor": "^0.55.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "react-virtuoso": "^4.18.3",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sharp": "0.34.5",
    "socks": "^2.8.7",
    "undici": "^8.1.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk-darwin-arm64": "0.2.119",
    "@anthropic-ai/claude-agent-sdk-darwin-x64": "0.2.119",
    "@anthropic-ai/claude-agent-sdk-linux-arm64": "0.2.119",
    "@anthropic-ai/claude-agent-sdk-linux-arm64-musl": "0.2.119",
    "@anthropic-ai/claude-agent-sdk-linux-x64": "0.2.119",
    "@anthropic-ai/claude-agent-sdk-linux-x64-musl": "0.2.119",
    "@anthropic-ai/claude-agent-sdk-win32-arm64": "0.2.119",
    "@anthropic-ai/claude-agent-sdk-win32-x64": "0.2.119",
    "@img/sharp-darwin-arm64": "*",
    "@img/sharp-darwin-x64": "*",
    "@img/sharp-linux-arm64": "*",
    "@img/sharp-linux-x64": "*",
    "@img/sharp-linuxmusl-arm64": "*",
    "@img/sharp-linuxmusl-x64": "*",
    "@img/sharp-win32-arm64": "*",
    "@img/sharp-win32-x64": "*"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "^9.39.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.17",
    "@tauri-apps/cli": "^2.9.6",
    "@types/adm-zip": "^0.5.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "tailwindcss": "^4.1.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.1.12",
    "vitest": "^3.2.4"
  }
}
